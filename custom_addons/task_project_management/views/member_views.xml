<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Member Form View -->
    <record id="view_member_form" model="ir.ui.view">
        <field name="name">task.management.member.form</field>
        <field name="model">task.management.member</field>
        <field name="arch" type="xml">
            <form string="Members" duplicate="0">
                <field name="is_current_user_admin" invisible="1"/>
                <field name="user_id" invisible="1"/>
                <header>
                    <button name="action_open_member_report" string="Performance Report"
                            type="object" class="btn-secondary"
                            invisible="not id"
                            groups="task_project_management.group_project_manager,task_project_management.group_admin_manager,task_project_management.group_manager"/>
                    <button name="action_assign_task"
                            string="Assign Task"
                            type="object" class="btn-primary"
                            invisible="not id"
                            groups="task_project_management.group_project_manager"/>
                    <button name="action_change_password"
                            string="Change Password"
                            type="object" class="btn-secondary"
                            invisible="not is_current_user_admin or not user_id"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="not is_current_user_admin and id"/>
                            <field name="email" readonly="not is_current_user_admin and id"/>
                            <field name="phone" readonly="not is_current_user_admin and id"/>
                        </group>
                        <group>
                            <field name="job_title" readonly="not is_current_user_admin and id"/>
                            <field name="role" readonly="not is_current_user_admin and id"/>
                        </group>
                    </group>
                    <group invisible="role != 'manager'" string="Manager Oversight">
                        <group>
                            <field name="supervise_all_projects"/>
                        </group>
                        <group>
                            <field name="supervised_project_ids"
                                   widget="many2many_tags"
                                   invisible="supervise_all_projects"
                                   domain="[('status', '!=', 'archived')]"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Managed Projects" name="managed_projects">
                            <field name="managed_project_ids" mode="tree">
                                <tree>
                                    <field name="name"/>
                                    <field name="status" widget="badge"
                                           decoration-success="status == 'active'"
                                           decoration-warning="status == 'on_hold'"
                                           decoration-info="status == 'completed'"
                                           decoration-muted="status == 'archived'"/>
                                    <field name="progress_percentage" widget="progressbar"/>
                                    <field name="total_logged_hours"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Member Projects" name="member_projects">
                            <field name="member_project_ids" mode="tree">
                                <tree>
                                    <field name="name"/>
                                    <field name="status" widget="badge"
                                           decoration-success="status == 'active'"
                                           decoration-warning="status == 'on_hold'"
                                           decoration-info="status == 'completed'"
                                           decoration-muted="status == 'archived'"/>
                                    <field name="progress_percentage" widget="progressbar"/>
                                    <field name="total_logged_hours"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Tasks" name="tasks">
                            <field name="task_ids" mode="tree">
                                <tree>
                                    <field name="date"/>
                                    <field name="project_id"/>
                                    <field name="description"/>
                                    <field name="duration_hours" widget="float_time"/>
                                    <field name="task_type" widget="badge"
                                           decoration-info="task_type == 'assigned'"
                                           decoration-muted="task_type == 'initiated'"/>
                                    <field name="approval_status" widget="badge"
                                           decoration-warning="approval_status == 'pending'"
                                           decoration-success="approval_status == 'approved'"
                                           decoration-danger="approval_status == 'rejected'"
                                           decoration-info="approval_status == 'assigned'"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Member Tree View -->
    <record id="view_member_tree" model="ir.ui.view">
        <field name="name">task.management.member.tree</field>
        <field name="model">task.management.member</field>
        <field name="arch" type="xml">
            <tree string="Members">
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="job_title"/>
                <field name="role" widget="badge"
                       decoration-info="role == 'member'"
                       decoration-warning="role == 'project_manager'"
                       decoration-danger="role == 'admin_manager'"
                       decoration-success="role == 'manager'"/>
            </tree>
        </field>
    </record>

    <!-- Member Search View -->
    <record id="view_member_search" model="ir.ui.view">
        <field name="name">task.management.member.search</field>
        <field name="model">task.management.member</field>
        <field name="arch" type="xml">
            <search string="Search Members">
                <field name="name"/>
                <field name="email"/>
                <field name="job_title"/>
                <group expand="0" string="Group By">
                    <filter string="Job Title" name="group_job_title"
                            context="{'group_by': 'job_title'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Member Action (Admin: sees everyone except admin) -->
    <record id="action_member" model="ir.actions.act_window">
        <field name="name">Members</field>
        <field name="res_model">task.management.member</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('role', '!=', 'admin_manager')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add a member
            </p>
        </field>
    </record>

    <!-- Member Action (PM: only members of managed projects, excludes self) -->
    <record id="action_pm_members" model="ir.actions.act_window">
        <field name="name">Members</field>
        <field name="res_model">task.management.member</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[
            ('member_project_ids.project_manager_ids.user_id', '=', uid),
            ('user_id', '!=', uid),
            ('role', 'not in', ['project_manager', 'admin_manager'])
        ]</field>
        <field name="context">{'create': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No members found in your projects
            </p>
        </field>
    </record>

</odoo>
