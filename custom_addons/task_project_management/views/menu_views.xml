<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Dashboard Client Actions                                      -->
    <!-- ============================================================ -->

    <record id="action_member_dashboard" model="ir.actions.client">
        <field name="name">My Dashboard</field>
        <field name="tag">task_project_management.member_dashboard</field>
    </record>

    <record id="action_pm_dashboard" model="ir.actions.client">
        <field name="name">PM Dashboard</field>
        <field name="tag">task_project_management.pm_dashboard</field>
    </record>

    <record id="action_admin_dashboard" model="ir.actions.client">
        <field name="name">Admin Dashboard</field>
        <field name="tag">task_project_management.admin_dashboard</field>
    </record>

    <!-- ============================================================ -->
    <!-- Hide Discuss and Apps menus                                   -->
    <!-- ============================================================ -->
    <record id="mail.menu_root_discuss" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <record id="base.menu_management" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <!-- ============================================================ -->
    <!-- Root Menu                                                     -->
    <!-- ============================================================ -->
    <menuitem id="menu_task_management_root"
              name="Task Management"
              sequence="50"
              web_icon="task_project_management,static/description/icon.png"/>

    <!-- ============================================================ -->
    <!-- Tasks Section (All roles)                                     -->
    <!-- ============================================================ -->
    <menuitem id="menu_my_tasks_parent"
              name="Tasks"
              parent="menu_task_management_root"
              sequence="10"
              groups="task_project_management.group_member,task_project_management.group_project_manager,task_project_management.group_admin_manager"/>

    <menuitem id="menu_my_tasks"
              name="My Tasks"
              parent="menu_my_tasks_parent"
              action="action_my_tasks"
              sequence="10"
              groups="task_project_management.group_member,task_project_management.group_project_manager"/>

    <menuitem id="menu_team_tasks"
              name="Team Tasks"
              parent="menu_my_tasks_parent"
              action="action_team_tasks"
              sequence="15"
              groups="task_project_management.group_project_manager"/>

    <menuitem id="menu_all_tasks"
              name="All Tasks"
              parent="menu_my_tasks_parent"
              action="action_all_tasks"
              sequence="18"
              groups="task_project_management.group_admin_manager"/>

    <menuitem id="menu_my_dashboard"
              name="My Dashboard"
              parent="menu_my_tasks_parent"
              action="action_member_dashboard"
              sequence="20"
              groups="task_project_management.group_member,task_project_management.group_project_manager"/>

    <!-- ============================================================ -->
    <!-- Projects Section (PM + Admin)                                 -->
    <!-- ============================================================ -->
    <menuitem id="menu_projects_parent"
              name="Projects"
              parent="menu_task_management_root"
              sequence="20"
              groups="task_project_management.group_project_manager,task_project_management.group_admin_manager"/>

    <menuitem id="menu_all_projects"
              name="Projects"
              parent="menu_projects_parent"
              action="action_project"
              sequence="10"/>

    <menuitem id="menu_tasks_to_review"
              name="Tasks to Review"
              parent="menu_projects_parent"
              action="action_tasks_to_review"
              sequence="20"/>

    <menuitem id="menu_pm_dashboard"
              name="PM Dashboard"
              parent="menu_projects_parent"
              action="action_pm_dashboard"
              sequence="30"/>

    <!-- ============================================================ -->
    <!-- Members Section (PM + Admin)                                  -->
    <!-- ============================================================ -->
    <menuitem id="menu_members_parent"
              name="Members"
              parent="menu_task_management_root"
              sequence="30"
              groups="task_project_management.group_project_manager,task_project_management.group_admin_manager"/>

    <menuitem id="menu_all_members"
              name="Members"
              parent="menu_members_parent"
              action="action_member"
              sequence="10"/>

    <!-- ============================================================ -->
    <!-- Archive / Portfolio (All roles)                                -->
    <!-- ============================================================ -->
    <menuitem id="menu_archive_parent"
              name="Archive / Portfolio"
              parent="menu_task_management_root"
              sequence="40"/>

    <menuitem id="menu_my_archive"
              name="My Archive"
              parent="menu_archive_parent"
              action="action_my_archive"
              sequence="10"/>

    <menuitem id="menu_public_archives"
              name="Browse Public Archives"
              parent="menu_archive_parent"
              action="action_public_archives"
              sequence="20"/>

    <!-- ============================================================ -->
    <!-- Administration (Admin only)                                   -->
    <!-- ============================================================ -->
    <menuitem id="menu_admin_parent"
              name="Administration"
              parent="menu_task_management_root"
              sequence="50"
              groups="task_project_management.group_admin_manager"/>

    <menuitem id="menu_admin_dashboard"
              name="Admin Dashboard"
              parent="menu_admin_parent"
              action="action_admin_dashboard"
              sequence="10"/>

    <menuitem id="menu_audit_trail"
              name="Audit Trail"
              parent="menu_admin_parent"
              action="action_task_audit"
              sequence="20"/>

    <menuitem id="menu_archived_projects"
              name="Archived Projects"
              parent="menu_admin_parent"
              action="action_project_archived"
              sequence="30"/>

    <!-- ============================================================ -->
    <!-- Configuration (Admin only)                                    -->
    <!-- ============================================================ -->
    <menuitem id="menu_config_parent"
              name="Configuration"
              parent="menu_task_management_root"
              sequence="60"
              groups="task_project_management.group_admin_manager"/>

    <menuitem id="menu_settings"
              name="Settings"
              parent="menu_config_parent"
              action="action_task_management_config"
              sequence="10"/>

</odoo>
