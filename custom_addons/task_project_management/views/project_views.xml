<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Project Form View -->
    <record id="view_project_form" model="ir.ui.view">
        <field name="name">task.management.project.form</field>
        <field name="model">task.management.project</field>
        <field name="arch" type="xml">
            <form string="Project Report" create="0" duplicate="0">
                <field name="is_admin_user" invisible="1"/>
                <header>
                    <button name="action_open_project_report" string="Project Report"
                            type="object" class="btn-secondary"
                            groups="task_project_management.group_project_manager,task_project_management.group_admin_manager,task_project_management.group_manager"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="waiting,active,on_hold,completed,archived"
                           options="{'clickable': True}"
                           readonly="id and not is_admin_user"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Project Name"
                                   readonly="id and not is_admin_user"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date_begin" readonly="id and not is_admin_user"/>
                            <field name="expected_end_date" readonly="id and not is_admin_user"/>
                        </group>
                        <group>
                            <field name="progress_percentage" widget="progressbar"/>
                            <field name="total_logged_hours"/>
                            <field name="task_count"/>
                            <field name="pending_task_count"/>
                            <field name="approved_task_count"/>
                            <field name="rejected_task_count"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Project description..."
                               readonly="id and not is_admin_user"/>
                    </group>
                    <notebook>
                        <page string="Phases" name="phases">
                            <field name="phase_ids">
                                <tree editable="bottom" delete="0"
                                      decoration-muted="not is_active or completion_rate == 100">
                                    <field name="project_id" column_invisible="1"/>
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="percentage"/>
                                    <field name="completion_rate"/>
                                    <field name="effective_progress"/>
                                    <field name="is_active" widget="boolean_toggle"/>
                                    <button name="action_delete_phase" type="object"
                                            icon="fa-trash" class="text-danger"
                                            confirm="Are you sure you want to delete this phase?"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Project Managers" name="managers">
                            <field name="project_manager_ids" widget="many2many_tags"
                                   domain="[('id', 'not in', member_ids), ('user_id.groups_id', 'in', %(task_project_management.group_project_manager)d)]"
                                   readonly="id and not is_admin_user"/>
                        </page>
                        <page string="Members" name="members">
                            <field name="member_ids"
                                   domain="[('id', 'not in', project_manager_ids), ('role', '!=', 'manager')]"
                                   readonly="id and not is_admin_user">
                                <tree>
                                    <field name="name"/>
                                    <field name="email"/>
                                    <field name="job_title"/>
                                    <field name="role"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Oversight Managers" name="oversight_managers"
                              groups="task_project_management.group_admin_manager">
                            <field name="manager_ids" widget="many2many_tags"
                                   domain="[('role', '=', 'manager')]"/>
                        </page>
                        <page string="Tasks" name="tasks">
                            <field name="task_ids" mode="tree">
                                <tree create="0" delete="0">
                                    <field name="date"/>
                                    <field name="member_id"/>
                                    <field name="description"/>
                                    <field name="duration_hours" widget="float_time"/>
                                    <field name="task_type" widget="badge"
                                           decoration-info="task_type == 'assigned'"
                                           decoration-muted="task_type == 'initiated'"/>
                                    <field name="approval_status" widget="badge"
                                           decoration-warning="approval_status == 'pending'"
                                           decoration-success="approval_status == 'approved'"
                                           decoration-danger="approval_status == 'rejected'"
                                           decoration-info="approval_status == 'assigned'"/>
                                    <field name="is_late_entry"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Project Tree View -->
    <record id="view_project_tree" model="ir.ui.view">
        <field name="name">task.management.project.tree</field>
        <field name="model">task.management.project</field>
        <field name="arch" type="xml">
            <tree string="Projects">
                <field name="name"/>
                <field name="status" widget="badge"
                       decoration-danger="status == 'waiting'"
                       decoration-success="status == 'active'"
                       decoration-warning="status == 'on_hold'"
                       decoration-info="status == 'completed'"
                       decoration-muted="status == 'archived'"/>
                <field name="date_begin"/>
                <field name="progress_percentage" widget="progressbar"/>
                <field name="expected_end_date"/>
                <field name="pending_task_count"/>
                <field name="approved_task_count"/>
                <field name="rejected_task_count"/>
            </tree>
        </field>
    </record>

    <!-- Project Search View -->
    <record id="view_project_search" model="ir.ui.view">
        <field name="name">task.management.project.search</field>
        <field name="model">task.management.project</field>
        <field name="arch" type="xml">
            <search string="Search Projects">
                <field name="name"/>
                <separator/>
                <filter string="Waiting" name="filter_waiting"
                        domain="[('status', '=', 'waiting')]"/>
                <filter string="Active" name="filter_active"
                        domain="[('status', '=', 'active')]"/>
                <filter string="On Hold" name="filter_on_hold"
                        domain="[('status', '=', 'on_hold')]"/>
                <filter string="Completed" name="filter_completed"
                        domain="[('status', '=', 'completed')]"/>
                <filter string="Archived" name="filter_archived"
                        domain="[('status', '=', 'archived')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_status"
                            context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Project Actions -->
    <record id="action_project" model="ir.actions.act_window">
        <field name="name">Projects</field>
        <field name="res_model">task.management.project</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No projects found
            </p>
        </field>
    </record>

    <!-- Archived Projects Action (Admin only) -->
    <record id="action_project_archived" model="ir.actions.act_window">
        <field name="name">Archived Projects</field>
        <field name="res_model">task.management.project</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('status', '=', 'archived')]</field>
    </record>

</odoo>
