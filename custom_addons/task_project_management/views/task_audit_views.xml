<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Audit Trail Tree View -->
    <record id="view_task_audit_tree" model="ir.ui.view">
        <field name="name">task.management.task.audit.tree</field>
        <field name="model">task.management.task.audit</field>
        <field name="arch" type="xml">
            <tree string="Audit Trail" create="0" edit="0" delete="0">
                <field name="task_id"/>
                <field name="changed_at"/>
                <field name="old_status" widget="badge"/>
                <field name="new_status" widget="badge"
                       decoration-warning="new_status == 'pending'"
                       decoration-success="new_status == 'approved'"
                       decoration-danger="new_status == 'rejected'"
                       decoration-info="new_status == 'assigned'"/>
                <field name="changed_by"/>
                <field name="previous_comment"/>
                <field name="comment"/>
            </tree>
        </field>
    </record>

    <!-- Audit Trail Search View -->
    <record id="view_task_audit_search" model="ir.ui.view">
        <field name="name">task.management.task.audit.search</field>
        <field name="model">task.management.task.audit</field>
        <field name="arch" type="xml">
            <search string="Search Audit Trail">
                <field name="task_id"/>
                <field name="changed_by"/>
                <separator/>
                <filter string="Approved" name="filter_approved"
                        domain="[('new_status', '=', 'approved')]"/>
                <filter string="Rejected" name="filter_rejected"
                        domain="[('new_status', '=', 'rejected')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Task" name="group_task"
                            context="{'group_by': 'task_id'}"/>
                    <filter string="Changed By" name="group_changed_by"
                            context="{'group_by': 'changed_by'}"/>
                    <filter string="New Status" name="group_status"
                            context="{'group_by': 'new_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Audit Trail Action -->
    <record id="action_task_audit" model="ir.actions.act_window">
        <field name="name">Audit Trail</field>
        <field name="res_model">task.management.task.audit</field>
        <field name="view_mode">tree</field>
    </record>

</odoo>
