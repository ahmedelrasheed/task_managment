<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Task Form View -->
    <record id="view_task_form" model="ir.ui.view">
        <field name="name">task.management.task.form</field>
        <field name="model">task.management.task</field>
        <field name="arch" type="xml">
            <form string="Task" delete="0">
                <header>
                    <field name="is_current_user_pm" invisible="1"/>
                    <field name="can_assign" invisible="1"/>
                    <field name="is_current_user_member" invisible="1"/>
                    <field name="assigned_by_id" invisible="1"/>
                    <button name="action_submit_work" string="Submit Work"
                            type="object" class="btn-success"
                            invisible="approval_status != 'assigned' or not is_current_user_member"/>
                    <button name="action_approve" string="Approve"
                            type="object" class="btn-primary"
                            invisible="approval_status != 'pending' or not is_current_user_pm"/>
                    <button name="action_reject" string="Reject"
                            type="object" class="btn-danger"
                            invisible="approval_status != 'pending' or not is_current_user_pm"/>
                    <field name="approval_status" widget="statusbar"
                           statusbar_visible="assigned,pending,approved,rejected"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-flag"
                                invisible="not is_late_entry">
                            <field name="is_late_entry" widget="boolean"
                                   string="Late Entry"/>
                            <span invisible="not is_late_entry">
                                (<field name="late_days"/> days)
                            </span>
                        </button>
                    </div>

                    <!-- Assignment Details (visible when creating or viewing an assignment) -->
                    <div class="alert alert-info" role="status"
                         invisible="not assigned_by_id and approval_status != 'assigned'">
                        <h5 class="alert-heading mb-2">
                            <i class="fa fa-tasks me-1"/>
                            Assignment Details
                        </h5>
                        <group>
                            <group>
                                <field name="assignment_name" string="Task Name"
                                       readonly="not can_assign or approval_status != 'assigned'"
                                       required="approval_status == 'assigned'"/>
                                <field name="due_date"
                                       readonly="not can_assign or approval_status != 'assigned'"/>
                            </group>
                            <group>
                                <field name="member_id" string="Assigned To"
                                       readonly="approval_status != 'assigned' or not can_assign"
                                       invisible="not assigned_by_id and approval_status != 'assigned'"/>
                                <field name="assigned_by_id" string="Assigned By"
                                       readonly="1"
                                       invisible="not assigned_by_id"/>
                            </group>
                        </group>
                        <group>
                            <field name="assignment_description"
                                   string="Instructions"
                                   readonly="not can_assign or approval_status != 'assigned'"/>
                        </group>
                        <group>
                            <field name="assignment_attachment_ids"
                                   widget="many2many_binary"
                                   string="Reference Files"
                                   readonly="not can_assign or approval_status != 'assigned'"/>
                        </group>
                    </div>

                    <group>
                        <group>
                            <field name="member_id"
                                   invisible="not is_current_user_pm or assigned_by_id or approval_status == 'assigned'"
                                   readonly="not can_assign or approval_status != 'assigned'"/>
                            <field name="project_id"
                                   readonly="approval_status == 'approved'"
                                   domain="[('status', 'in', ['waiting', 'active'])]"
                                   context="{'restrict_to_member_projects': True}"
                                   options="{'no_create': True}"/>
                        </group>
                        <!-- Work fields: hidden when PM/Admin views an assigned task (no work data yet) -->
                        <group invisible="approval_status == 'assigned' and not is_current_user_member">
                            <field name="date"
                                   readonly="approval_status == 'approved'"/>
                            <field name="time_from" widget="float_time_spinner"
                                   readonly="approval_status == 'approved'"/>
                            <field name="time_to" widget="float_time_spinner"
                                   readonly="approval_status == 'approved'"/>
                            <field name="duration_hours" widget="float_time"
                                   readonly="1"/>
                            <field name="entry_timestamp" readonly="1"/>
                        </group>
                    </group>
                    <group invisible="approval_status == 'assigned' and not is_current_user_member">
                        <field name="description"
                               readonly="approval_status == 'approved'"
                               placeholder="Describe the work done..."/>
                    </group>
                    <group invisible="approval_status == 'assigned' and not is_current_user_member">
                        <field name="attachment_ids" widget="many2many_binary"
                               readonly="approval_status == 'approved'"
                               string="Attachments"/>
                    </group>
                    <group string="Manager Review"
                           groups="task_project_management.group_project_manager">
                        <field name="manager_comment"
                               placeholder="Add your comment..."/>
                    </group>
                    <group string="Manager Comment"
                           groups="!task_project_management.group_project_manager">
                        <field name="manager_comment" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Audit Trail" name="audit_trail">
                            <field name="audit_ids" readonly="1">
                                <tree>
                                    <field name="changed_at"/>
                                    <field name="old_status" widget="badge"/>
                                    <field name="new_status" widget="badge"
                                           decoration-warning="new_status == 'pending'"
                                           decoration-success="new_status == 'approved'"
                                           decoration-danger="new_status == 'rejected'"
                                           decoration-info="new_status == 'assigned'"/>
                                    <field name="changed_by"/>
                                    <field name="comment"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Task Tree View -->
    <record id="view_task_tree" model="ir.ui.view">
        <field name="name">task.management.task.tree</field>
        <field name="model">task.management.task</field>
        <field name="arch" type="xml">
            <tree string="Tasks" delete="0"
                  decoration-warning="approval_status == 'pending'"
                  decoration-success="approval_status == 'approved'"
                  decoration-danger="approval_status == 'rejected'"
                  decoration-info="approval_status == 'assigned'">
                <field name="date"/>
                <field name="project_id"/>
                <field name="member_id" optional="hide"/>
                <field name="assignment_name" string="Task Name" optional="show"/>
                <field name="description"/>
                <field name="time_from" widget="float_time"/>
                <field name="time_to" widget="float_time"/>
                <field name="duration_hours" widget="float_time" sum="Total Hours"/>
                <field name="due_date" optional="show"/>
                <field name="approval_status" widget="badge"
                       decoration-warning="approval_status == 'pending'"
                       decoration-success="approval_status == 'approved'"
                       decoration-danger="approval_status == 'rejected'"
                       decoration-info="approval_status == 'assigned'"/>
                <field name="is_late_entry" optional="show"/>
            </tree>
        </field>
    </record>

    <!-- Task Search View -->
    <record id="view_task_search" model="ir.ui.view">
        <field name="name">task.management.task.search</field>
        <field name="model">task.management.task</field>
        <field name="arch" type="xml">
            <search string="Search Tasks">
                <field name="description"/>
                <field name="project_id"/>
                <field name="member_id"/>
                <field name="assignment_name"/>
                <separator/>
                <filter string="Assigned" name="filter_assigned"
                        domain="[('approval_status', '=', 'assigned')]"/>
                <filter string="Pending" name="filter_pending"
                        domain="[('approval_status', '=', 'pending')]"/>
                <filter string="Approved" name="filter_approved"
                        domain="[('approval_status', '=', 'approved')]"/>
                <filter string="Rejected" name="filter_rejected"
                        domain="[('approval_status', '=', 'rejected')]"/>
                <separator/>
                <filter string="Today" name="filter_today"
                        domain="[('date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="This Week" name="filter_this_week"
                        domain="[
                            ('date', '>=', (context_today() - datetime.timedelta(days=context_today().weekday())).strftime('%Y-%m-%d')),
                            ('date', '&lt;=', (context_today() + datetime.timedelta(days=6-context_today().weekday())).strftime('%Y-%m-%d'))
                        ]"/>
                <filter string="This Month" name="filter_this_month"
                        domain="[
                            ('date', '>=', context_today().strftime('%Y-%m-01')),
                            ('date', '&lt;=', context_today().strftime('%Y-%m-%d'))
                        ]"/>
                <separator/>
                <filter string="Late Entries" name="filter_late"
                        domain="[('is_late_entry', '=', True)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Project" name="group_project"
                            context="{'group_by': 'project_id'}"/>
                    <filter string="Date" name="group_date"
                            context="{'group_by': 'date'}"/>
                    <filter string="Status" name="group_status"
                            context="{'group_by': 'approval_status'}"/>
                    <filter string="Member" name="group_member"
                            context="{'group_by': 'member_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Task Tree View (with Member column visible) for PM/Admin -->
    <record id="view_task_tree_with_member" model="ir.ui.view">
        <field name="name">task.management.task.tree.withmember</field>
        <field name="model">task.management.task</field>
        <field name="arch" type="xml">
            <tree string="Tasks" delete="0"
                  decoration-warning="approval_status == 'pending'"
                  decoration-success="approval_status == 'approved'"
                  decoration-danger="approval_status == 'rejected'"
                  decoration-info="approval_status == 'assigned'">
                <field name="date"/>
                <field name="project_id"/>
                <field name="member_id"/>
                <field name="assignment_name" string="Task Name" optional="show"/>
                <field name="description"/>
                <field name="time_from" widget="float_time"/>
                <field name="time_to" widget="float_time"/>
                <field name="duration_hours" widget="float_time" sum="Total Hours"/>
                <field name="due_date" optional="show"/>
                <field name="approval_status" widget="badge"
                       decoration-warning="approval_status == 'pending'"
                       decoration-success="approval_status == 'approved'"
                       decoration-danger="approval_status == 'rejected'"
                       decoration-info="approval_status == 'assigned'"/>
                <field name="is_late_entry" optional="show"/>
            </tree>
        </field>
    </record>

    <!-- My Tasks Action (own submitted tasks only) -->
    <record id="action_my_tasks" model="ir.actions.act_window">
        <field name="name">My Tasks</field>
        <field name="res_model">task.management.task</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('member_id.user_id', '=', uid)]</field>
        <field name="context">{
            'search_default_filter_pending': 0,
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add a new task entry
            </p>
        </field>
    </record>

    <!-- Team Tasks Action (PM: tasks from supervised projects) -->
    <record id="action_team_tasks" model="ir.actions.act_window">
        <field name="name">Team Tasks</field>
        <field name="res_model">task.management.task</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('project_id.project_manager_ids.user_id', '=', uid)]</field>
        <field name="view_id" ref="view_task_tree_with_member"/>
        <field name="context">{
            'search_default_group_project': 1,
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No tasks from your team yet
            </p>
        </field>
    </record>

    <!-- All Tasks Action (Admin: everything) -->
    <record id="action_all_tasks" model="ir.actions.act_window">
        <field name="name">All Tasks</field>
        <field name="res_model">task.management.task</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_task_tree_with_member"/>
        <field name="context">{
            'search_default_group_project': 1,
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No tasks in the system yet
            </p>
        </field>
    </record>

    <!-- Tasks to Review Action (PM) -->
    <record id="action_tasks_to_review" model="ir.actions.act_window">
        <field name="name">Tasks to Review</field>
        <field name="res_model">task.management.task</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_task_tree_with_member"/>
        <field name="context">{
            'search_default_filter_pending': 1,
            'search_default_group_project': 1,
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No pending tasks to review
            </p>
        </field>
    </record>

    <!-- Assign Task Action (PM creates assignment) -->
    <record id="action_assign_task" model="ir.actions.act_window">
        <field name="name">Assign Task</field>
        <field name="res_model">task.management.task</field>
        <field name="view_mode">form</field>
        <field name="context">{
            'default_approval_status': 'assigned',
            'default_member_id': False,
            'form_view_initial_mode': 'edit',
        }</field>
        <field name="target">current</field>
    </record>

    <!-- My Assignments Action (member sees assigned tasks) -->
    <record id="action_my_assignments" model="ir.actions.act_window">
        <field name="name">My Assignments</field>
        <field name="res_model">task.management.task</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('member_id.user_id', '=', uid), ('assigned_by_id', '!=', False)]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No tasks have been assigned to you yet
            </p>
        </field>
    </record>

    <!-- Assigned Tasks Action (PM sees tasks they assigned) -->
    <record id="action_assigned_tasks" model="ir.actions.act_window">
        <field name="name">Assigned Tasks</field>
        <field name="res_model">task.management.task</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_task_tree_with_member"/>
        <field name="domain">[('assigned_by_id.user_id', '=', uid)]</field>
        <field name="context">{
            'search_default_group_project': 1,
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                You haven't assigned any tasks yet
            </p>
        </field>
    </record>

</odoo>
