<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Daily cron job to check project deadlines -->
    <record id="cron_check_project_deadlines" model="ir.cron">
        <field name="name">Task Management: Check Project Deadlines</field>
        <field name="model_id" ref="model_task_management_project"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_project_deadlines()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True"/>
    </record>

</odoo>
