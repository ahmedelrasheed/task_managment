<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Default configuration parameters -->
    <record id="config_past_date_limit" model="ir.config_parameter" forcecreate="False">
        <field name="key">task_project_management.past_date_limit</field>
        <field name="value">7</field>
    </record>

    <record id="config_allow_after_midnight" model="ir.config_parameter" forcecreate="False">
        <field name="key">task_project_management.allow_after_midnight</field>
        <field name="value">False</field>
    </record>

    <record id="config_max_attachment_size" model="ir.config_parameter" forcecreate="False">
        <field name="key">task_project_management.max_attachment_size</field>
        <field name="value">100</field>
    </record>

    <record id="config_daily_hours_average" model="ir.config_parameter" forcecreate="False">
        <field name="key">task_project_management.daily_hours_average</field>
        <field name="value">8.0</field>
    </record>

    <record id="config_weekly_hours_average" model="ir.config_parameter" forcecreate="False">
        <field name="key">task_project_management.weekly_hours_average</field>
        <field name="value">40.0</field>
    </record>

</odoo>
