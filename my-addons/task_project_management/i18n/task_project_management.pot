#. module: task_project_management
#: model:mail.template,body_html:task_project_management.mail_template_task_submitted
msgid ""
"\n"
"<div style=\"margin: 0px; padding: 0px;\">\n"
"    <p>Dear Project Manager,</p>\n"
"    <p>A new task has been submitted for your review:</p>\n"
"    <ul>\n"
"        <li><strong>Project:</strong> {{ object.project_id.name }}</li>\n"
"        <li><strong>Member:</strong> {{ object.member_id.name }}</li>\n"
"        <li><strong>Date:</strong> {{ object.date }}</li>\n"
"        <li><strong>Description:</strong> {{ object.description[:100] }}</li>\n"
"        <li><strong>Time:</strong> {{ '%02d:%02d'|format(object.time_from|int, ((object.time_from - object.time_from|int) * 60)|int) }} - {{ '%02d:%02d'|format(object.time_to|int, ((object.time_to - object.time_to|int) * 60)|int) }}</li>\n"
"    </ul>\n"
"    <p>Please review and approve or reject this task.</p>\n"
"</div>\n"
msgstr ""

#. module: task_project_management
#: model:mail.template,body_html:task_project_management.mail_template_task_status_changed
msgid ""
"\n"
"<div style=\"margin: 0px; padding: 0px;\">\n"
"    <p>Dear {{ object.member_id.name }},</p>\n"
"    <p>Your task status has been updated:</p>\n"
"    <ul>\n"
"        <li><strong>Project:</strong> {{ object.project_id.name }}</li>\n"
"        <li><strong>Date:</strong> {{ object.date }}</li>\n"
"        <li><strong>Description:</strong> {{ object.description[:100] }}</li>\n"
"        <li><strong>Status:</strong> {{ object.approval_status }}</li>\n"
"        {% if object.manager_comment %}\n"
"        <li><strong>Manager Comment:</strong> {{ object.manager_comment }}</li>\n"
"        {% endif %}\n"
"    </ul>\n"
"</div>\n"
msgstr ""

#. module: task_project_management
#: model:mail.template,body_html:task_project_management.mail_template_project_deadline
msgid ""
"\n"
"<div style=\"margin: 0px; padding: 0px;\">\n"
"    <p>Warning: Project deadline reached!</p>\n"
"    <ul>\n"
"        <li><strong>Project:</strong> {{ object.name }}</li>\n"
"        <li><strong>Expected End Date:</strong> {{ object.expected_end_date }}</li>\n"
"        <li><strong>Pending Tasks:</strong> {{ object.pending_task_count }}</li>\n"
"        <li><strong>Progress:</strong> {{ '%.1f'|format(object.progress_percentage) }}%</li>\n"
"    </ul>\n"
"    <p>Please review and take appropriate action.</p>\n"
"</div>\n"
msgstr ""

