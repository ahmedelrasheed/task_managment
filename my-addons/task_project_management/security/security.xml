<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================ -->
    <!-- Security Groups                                              -->
    <!-- ============================================================ -->

    <record id="module_category_task_management" model="ir.module.category">
        <field name="name">Task Management</field>
        <field name="sequence">50</field>
    </record>

    <record id="group_member" model="res.groups">
        <field name="name">Member</field>
        <field name="category_id" ref="module_category_task_management"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!--
        PM implies base.group_user directly (NOT group_member).
        This prevents member-level record rules from OR'ing with PM rules,
        so PMs only see projects they manage, not projects they're a member of.
    -->
    <record id="group_project_manager" model="res.groups">
        <field name="name">Project Manager</field>
        <field name="category_id" ref="module_category_task_management"/>
        <field name="implied_ids" eval="[(6, 0, [ref('base.group_user')])]"/>
    </record>

    <record id="group_admin_manager" model="res.groups">
        <field name="name">Admin Manager</field>
        <field name="category_id" ref="module_category_task_management"/>
        <field name="implied_ids" eval="[(6, 0, [ref('base.group_user')])]"/>
    </record>

    <!--
        Manager: read-only oversight role. Does NOT imply any other TM group.
        Visibility controlled via project.manager_ids (admin assigns projects).
    -->
    <record id="group_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_task_management"/>
        <field name="implied_ids" eval="[(6, 0, [ref('base.group_user')])]"/>
    </record>

    <!-- ============================================================ -->
    <!-- Record Rules                                                 -->
    <!-- ============================================================ -->

    <!-- === TASK RULES === -->
    <!-- Member: own tasks only -->
    <record id="rule_task_member" model="ir.rule">
        <field name="name">Task: Member sees own tasks</field>
        <field name="model_id" ref="model_task_management_task"/>
        <field name="domain_force">[('member_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_member'))]"/>
    </record>

    <!-- PM: tasks in managed projects + own tasks in member projects -->
    <record id="rule_task_pm" model="ir.rule">
        <field name="name">Task: PM sees managed project tasks + own tasks</field>
        <field name="model_id" ref="model_task_management_task"/>
        <field name="domain_force">[
            '|',
            ('project_id.project_manager_ids.user_id', '=', user.id),
            ('member_id.user_id', '=', user.id)
        ]</field>
        <field name="groups" eval="[(4, ref('group_project_manager'))]"/>
    </record>

    <!-- Admin: all tasks -->
    <record id="rule_task_admin" model="ir.rule">
        <field name="name">Task: Admin sees all tasks</field>
        <field name="model_id" ref="model_task_management_task"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_admin_manager'))]"/>
    </record>

    <!-- === PROJECT RULES === -->
    <!-- Member: assigned waiting/active/on_hold/completed projects -->
    <record id="rule_project_member" model="ir.rule">
        <field name="name">Project: Member sees assigned non-archived</field>
        <field name="model_id" ref="model_task_management_project"/>
        <field name="domain_force">[
            ('member_ids.user_id', '=', user.id),
            ('status', 'in', ['waiting', 'active', 'on_hold', 'completed'])
        ]</field>
        <field name="groups" eval="[(4, ref('group_member'))]"/>
    </record>

    <!-- PM: managed projects + member projects (not archived) -->
    <record id="rule_project_pm" model="ir.rule">
        <field name="name">Project: PM sees managed + member projects non-archived</field>
        <field name="model_id" ref="model_task_management_project"/>
        <field name="domain_force">[
            '|',
            ('project_manager_ids.user_id', '=', user.id),
            ('member_ids.user_id', '=', user.id),
            ('status', '!=', 'archived')
        ]</field>
        <field name="groups" eval="[(4, ref('group_project_manager'))]"/>
        <field name="active" eval="True"/>
    </record>

    <!-- Admin: all projects -->
    <record id="rule_project_admin" model="ir.rule">
        <field name="name">Project: Admin sees all</field>
        <field name="model_id" ref="model_task_management_project"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_admin_manager'))]"/>
    </record>

    <!-- === MEMBER RULES === -->
    <!-- Member: own profile only -->
    <record id="rule_member_member" model="ir.rule">
        <field name="name">Member: sees own profile</field>
        <field name="model_id" ref="model_task_management_member"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_member'))]"/>
    </record>

    <!-- PM: members in managed projects + own -->
    <record id="rule_member_pm" model="ir.rule">
        <field name="name">Member: PM sees members in managed projects</field>
        <field name="model_id" ref="model_task_management_member"/>
        <field name="domain_force">[
            '|',
            ('user_id', '=', user.id),
            ('member_project_ids.project_manager_ids.user_id', '=', user.id)
        ]</field>
        <field name="groups" eval="[(4, ref('group_project_manager'))]"/>
    </record>

    <!-- Admin: all members -->
    <record id="rule_member_admin" model="ir.rule">
        <field name="name">Member: Admin sees all</field>
        <field name="model_id" ref="model_task_management_member"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_admin_manager'))]"/>
    </record>

    <!-- === ARCHIVE RULES === -->
    <!-- Any user: own + public entries -->
    <record id="rule_archive_member" model="ir.rule">
        <field name="name">Archive: User sees own + public</field>
        <field name="model_id" ref="model_task_management_archive"/>
        <field name="domain_force">[
            '|',
            ('user_id', '=', user.id),
            ('visibility', '=', 'public')
        ]</field>
        <field name="groups" eval="[(6, 0, [ref('base.group_user')])]"/>
    </record>

    <!-- Admin: all archive entries -->
    <record id="rule_archive_admin" model="ir.rule">
        <field name="name">Archive: Admin sees all</field>
        <field name="model_id" ref="model_task_management_archive"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_admin_manager'))]"/>
    </record>

    <!-- === PHASE RULES (follow project visibility) === -->
    <!-- Member: phases of assigned projects -->
    <record id="rule_phase_member" model="ir.rule">
        <field name="name">Phase: Member sees phases of assigned projects</field>
        <field name="model_id" ref="model_task_management_project_phase"/>
        <field name="domain_force">[
            ('project_id.member_ids.user_id', '=', user.id),
            ('project_id.status', 'in', ['waiting', 'active', 'on_hold', 'completed'])
        ]</field>
        <field name="groups" eval="[(4, ref('group_member'))]"/>
    </record>

    <!-- PM: phases of managed + member projects -->
    <record id="rule_phase_pm" model="ir.rule">
        <field name="name">Phase: PM sees phases of managed + member projects</field>
        <field name="model_id" ref="model_task_management_project_phase"/>
        <field name="domain_force">[
            '|',
            ('project_id.project_manager_ids.user_id', '=', user.id),
            ('project_id.member_ids.user_id', '=', user.id),
            ('project_id.status', '!=', 'archived')
        ]</field>
        <field name="groups" eval="[(4, ref('group_project_manager'))]"/>
    </record>

    <!-- Admin: all phases -->
    <record id="rule_phase_admin" model="ir.rule">
        <field name="name">Phase: Admin sees all</field>
        <field name="model_id" ref="model_task_management_project_phase"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_admin_manager'))]"/>
    </record>

    <!-- === AUDIT RULES (follow task visibility) === -->
    <!-- Member: audit for own tasks -->
    <record id="rule_audit_member" model="ir.rule">
        <field name="name">Audit: Member sees own task audit</field>
        <field name="model_id" ref="model_task_management_task_audit"/>
        <field name="domain_force">[('task_id.member_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_member'))]"/>
    </record>

    <!-- PM: audit for managed project tasks + own tasks -->
    <record id="rule_audit_pm" model="ir.rule">
        <field name="name">Audit: PM sees managed project audit + own task audit</field>
        <field name="model_id" ref="model_task_management_task_audit"/>
        <field name="domain_force">[
            '|',
            ('task_id.project_id.project_manager_ids.user_id', '=', user.id),
            ('task_id.member_id.user_id', '=', user.id)
        ]</field>
        <field name="groups" eval="[(4, ref('group_project_manager'))]"/>
    </record>

    <!-- Admin: all audit -->
    <record id="rule_audit_admin" model="ir.rule">
        <field name="name">Audit: Admin sees all</field>
        <field name="model_id" ref="model_task_management_task_audit"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_admin_manager'))]"/>
    </record>

    <!-- ============================================================ -->
    <!-- Manager Record Rules (oversight via project.manager_ids)     -->
    <!-- ============================================================ -->

    <!-- Manager: tasks from admin-assigned projects -->
    <record id="rule_task_manager" model="ir.rule">
        <field name="name">Task: Manager sees tasks from assigned projects</field>
        <field name="model_id" ref="model_task_management_task"/>
        <field name="domain_force">[('project_id.manager_ids.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_manager'))]"/>
    </record>

    <!-- Manager: projects assigned by admin -->
    <record id="rule_project_manager_role" model="ir.rule">
        <field name="name">Project: Manager sees assigned projects</field>
        <field name="model_id" ref="model_task_management_project"/>
        <field name="domain_force">[('manager_ids.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_manager'))]"/>
    </record>

    <!-- Manager: all members (read-only via ACL) -->
    <record id="rule_member_manager" model="ir.rule">
        <field name="name">Member: Manager sees all members</field>
        <field name="model_id" ref="model_task_management_member"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_manager'))]"/>
    </record>

    <!-- Manager: phases from assigned projects -->
    <record id="rule_phase_manager" model="ir.rule">
        <field name="name">Phase: Manager sees phases of assigned projects</field>
        <field name="model_id" ref="model_task_management_project_phase"/>
        <field name="domain_force">[('project_id.manager_ids.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_manager'))]"/>
    </record>

    <!-- Manager: audit from assigned project tasks -->
    <record id="rule_audit_manager" model="ir.rule">
        <field name="name">Audit: Manager sees audit of assigned projects</field>
        <field name="model_id" ref="model_task_management_task_audit"/>
        <field name="domain_force">[('task_id.project_id.manager_ids.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_manager'))]"/>
    </record>


</odoo>
