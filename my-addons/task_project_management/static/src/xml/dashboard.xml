<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <!-- Member Dashboard -->
    <t t-name="task_project_management.MemberDashboard">
        <Layout display="display" className="'o_action task_dashboard member_dashboard'">
            <div class="container-fluid py-3">

                <!-- Header with Logo -->
                <div class="dashboard-header">
                    <div class="header-left">
                        <img class="company-logo" src="/web/binary/company_logo" t-att-alt="_t('Logo')"/>
                        <div>
                            <h2 class="dashboard-title"><t t-esc="_t('My Dashboard')"/></h2>
                            <p class="company-name" t-esc="state.companyName"/>
                        </div>
                    </div>
                </div>

                <!-- KPI Cards -->
                <div class="row mb-4">
                    <div class="col">
                        <div class="card kpi-card bg-primary text-white">
                            <div class="card-body text-center">
                                <h5 class="card-title"><t t-esc="_t('Total Tasks')"/></h5>
                                <h2 class="kpi-value" t-esc="state.totalTasks"/>
                            </div>
                        </div>
                    </div>
                    <div class="col" t-if="state.assignedTasks > 0">
                        <div class="card kpi-card bg-info text-white">
                            <div class="card-body text-center">
                                <h5 class="card-title"><t t-esc="_t('Assigned')"/></h5>
                                <h2 class="kpi-value" t-esc="state.assignedTasks"/>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card kpi-card bg-warning text-white">
                            <div class="card-body text-center">
                                <h5 class="card-title"><t t-esc="_t('Pending')"/></h5>
                                <h2 class="kpi-value" t-esc="state.pendingTasks"/>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card kpi-card bg-success text-white">
                            <div class="card-body text-center">
                                <h5 class="card-title"><t t-esc="_t('Approved')"/></h5>
                                <h2 class="kpi-value" t-esc="state.approvedTasks"/>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card kpi-card bg-danger text-white">
                            <div class="card-body text-center">
                                <h5 class="card-title"><t t-esc="_t('Rejected')"/></h5>
                                <h2 class="kpi-value" t-esc="state.rejectedTasks"/>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Hours Summary -->
                <div class="row mb-4">
                    <div class="col-md-4">
                        <div class="card">
                            <div class="card-body text-center">
                                <h6 class="text-muted"><t t-esc="_t('Today')"/></h6>
                                <h3><t t-esc="state.hoursToday"/> <t t-esc="_t('hrs')"/></h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card">
                            <div class="card-body text-center">
                                <h6 class="text-muted"><t t-esc="_t('This Week')"/></h6>
                                <h3><t t-esc="state.hoursWeek"/> <t t-esc="_t('hrs')"/></h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card">
                            <div class="card-body text-center">
                                <h6 class="text-muted"><t t-esc="_t('This Month')"/></h6>
                                <h3><t t-esc="state.hoursMonth"/> <t t-esc="_t('hrs')"/></h3>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Performance Metrics -->
                <div class="row mb-4">
                    <div class="col-md-4">
                        <div class="card perf-card">
                            <div class="card-body text-center">
                                <h6 class="text-muted"><t t-esc="_t('Daily Performance')"/></h6>
                                <h3 t-attf-class="#{state.dailyPerformance >= 100 ? 'text-success' : state.dailyPerformance >= 75 ? 'text-warning' : 'text-danger'}">
                                    <t t-esc="state.dailyPerformance"/>%
                                </h3>
                                <small class="text-muted">
                                    <t t-esc="state.hoursToday"/> / <t t-esc="state.dailyTarget"/> <t t-esc="_t('hrs target')"/>
                                </small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card perf-card">
                            <div class="card-body text-center">
                                <h6 class="text-muted"><t t-esc="_t('Weekly Performance')"/></h6>
                                <h3 t-attf-class="#{state.weeklyPerformance >= 100 ? 'text-success' : state.weeklyPerformance >= 75 ? 'text-warning' : 'text-danger'}">
                                    <t t-esc="state.weeklyPerformance"/>%
                                </h3>
                                <small class="text-muted">
                                    <t t-esc="state.hoursWeek"/> / <t t-esc="state.weeklyTarget"/> <t t-esc="_t('hrs target')"/>
                                </small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card perf-card">
                            <div class="card-body text-center">
                                <h6 class="text-muted"><t t-esc="_t('Monthly Performance')"/></h6>
                                <h3 t-attf-class="#{state.monthlyPerformance >= 100 ? 'text-success' : state.monthlyPerformance >= 75 ? 'text-warning' : 'text-danger'}">
                                    <t t-esc="state.monthlyPerformance"/>%
                                </h3>
                                <small class="text-muted">
                                    <t t-esc="state.hoursMonth"/> / <t t-esc="state.monthlyTarget"/> <t t-esc="_t('hrs target')"/>
                                </small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Recent Tasks -->
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header">
                                <h5><t t-esc="_t('Recent Tasks')"/></h5>
                            </div>
                            <div class="card-body p-0">
                                <table class="table table-striped mb-0">
                                    <thead>
                                        <tr>
                                            <th><t t-esc="_t('Date')"/></th>
                                            <th><t t-esc="_t('Project')"/></th>
                                            <th><t t-esc="_t('Description')"/></th>
                                            <th><t t-esc="_t('Hours')"/></th>
                                            <th><t t-esc="_t('Task Type')"/></th>
                                            <th><t t-esc="_t('Status')"/></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="state.recentTasks" t-as="task" t-key="task.id">
                                            <tr>
                                                <td t-esc="task.date"/>
                                                <td t-esc="task.project"/>
                                                <td t-esc="task.description"/>
                                                <td t-esc="task.hours"/>
                                                <td>
                                                    <span t-attf-class="badge #{task.task_type === 'assigned' ? 'text-bg-info' : 'text-bg-secondary'}"
                                                          t-esc="task.task_type_display or task.task_type"/>
                                                </td>
                                                <td>
                                                    <span t-attf-class="badge #{task.status === 'approved' ? 'text-bg-success' : task.status === 'rejected' ? 'text-bg-danger' : task.status === 'assigned' ? 'text-bg-info' : 'text-bg-warning'}"
                                                          t-esc="task.status_display or task.status"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Upcoming Meetings -->
                <div class="row mt-4">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h5 class="mb-0"><t t-esc="_t('Upcoming Meetings')"/></h5>
                                <div>
                                    <span class="badge text-bg-primary me-2">
                                        <t t-esc="_t('Today:')"/> <t t-esc="state.meetingsToday"/>
                                    </span>
                                    <span class="badge text-bg-info">
                                        <t t-esc="_t('This Week:')"/> <t t-esc="state.meetingsThisWeek"/>
                                    </span>
                                </div>
                            </div>
                            <div class="card-body p-0">
                                <t t-if="state.upcomingMeetings.length">
                                    <table class="table table-striped mb-0">
                                        <thead>
                                            <tr>
                                                <th><t t-esc="_t('Date')"/></th>
                                                <th><t t-esc="_t('Time')"/></th>
                                                <th><t t-esc="_t('Meeting')"/></th>
                                                <th><t t-esc="_t('Project')"/></th>
                                                <th><t t-esc="_t('Type')"/></th>
                                                <th><t t-esc="_t('Mode')"/></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="state.upcomingMeetings" t-as="meeting" t-key="meeting.id">
                                                <tr>
                                                    <td t-esc="meeting.date"/>
                                                    <td t-esc="meeting.time_display"/>
                                                    <td t-esc="meeting.name"/>
                                                    <td t-esc="meeting.project"/>
                                                    <td>
                                                        <span t-attf-class="badge #{meeting.meeting_type === 'project_review' ? 'text-bg-info' : meeting.meeting_type === 'task_review' ? 'text-bg-success' : meeting.meeting_type === 'team_meeting' ? 'text-bg-warning' : 'text-bg-secondary'}"
                                                              t-esc="meeting.meeting_type_display or meeting.meeting_type"/>
                                                    </td>
                                                    <td>
                                                        <span t-attf-class="badge #{meeting.meeting_mode === 'online' ? 'text-bg-info' : meeting.meeting_mode === 'in_person' ? 'text-bg-success' : 'text-bg-warning'}"
                                                              t-esc="meeting.meeting_mode_display or meeting.meeting_mode"/>
                                                        <a t-if="(meeting.meeting_mode === 'online' || meeting.meeting_mode === 'hybrid') &amp;&amp; meeting.meeting_link"
                                                           t-att-href="meeting.meeting_link"
                                                           target="_blank"
                                                           class="btn btn-sm btn-outline-primary ms-1">
                                                            <i class="fa fa-video-camera"/> <t t-esc="_t('Join')"/>
                                                        </a>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </t>
                                <t t-else="">
                                    <div class="text-center text-muted py-4">
                                        <i class="fa fa-calendar-o fa-2x mb-2 d-block"/>
                                        <p><t t-esc="_t('No upcoming meetings')"/></p>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </Layout>
    </t>

    <!-- PM Dashboard -->
    <t t-name="task_project_management.PMDashboard">
        <Layout display="display" className="'o_action task_dashboard pm_dashboard'">
            <div class="container-fluid py-3">

                <!-- Header with Logo -->
                <div class="dashboard-header">
                    <div class="header-left">
                        <img class="company-logo" src="/web/binary/company_logo" t-att-alt="_t('Logo')"/>
                        <div>
                            <h2 class="dashboard-title"><t t-esc="_t('Project Manager Dashboard')"/></h2>
                            <p class="company-name" t-esc="state.companyName"/>
                        </div>
                    </div>
                    <div class="header-actions">
                        <button class="btn btn-outline-light me-2"
                                t-on-click="onExportCSV">
                            <i class="fa fa-file-text-o"/> CSV
                        </button>
                        <button class="btn btn-outline-light me-2"
                                t-on-click="onExportPDF">
                            <i class="fa fa-file-pdf-o"/> PDF
                        </button>
                        <button class="btn btn-outline-light"
                                t-on-click="onExportImage">
                            <i class="fa fa-image"/> <t t-esc="_t('Image')"/>
                        </button>
                    </div>
                </div>

                <!-- No projects message -->
                <t t-if="!state.projects.length">
                    <div class="card mb-3">
                        <div class="card-body text-center text-muted py-5">
                            <i class="fa fa-folder-open-o fa-3x mb-3 d-block"/>
                            <h5><t t-esc="_t('No projects found')"/></h5>
                            <p><t t-esc="_t('Projects you manage will appear here.')"/></p>
                        </div>
                    </div>
                </t>

                <!-- Project Progress Cards -->
                <t t-foreach="state.projects" t-as="project" t-key="project.id">
                    <div class="card project-card mb-3">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0" t-esc="project.name"/>
                            <span t-attf-class="badge #{project.status === 'active' ? 'text-bg-success' : project.status === 'waiting' ? 'text-bg-danger' : 'text-bg-warning'}"
                                  t-esc="project.status_display || project.status"/>
                        </div>
                        <div class="card-body">
                            <div class="row mb-3">
                                <div class="col-md-8">
                                    <div class="progress" style="height: 25px;">
                                        <div class="progress-bar"
                                             role="progressbar"
                                             t-attf-style="width: #{project.progress}%"
                                             t-att-aria-valuenow="project.progress"
                                             aria-valuemin="0" aria-valuemax="100">
                                            <t t-esc="project.progress"/>% <t t-esc="_t('Complete')"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4 text-end">
                                    <span class="text-muted me-2" t-if="project.assigned_tasks">
                                        <t t-esc="_t('Assigned:')"/> <strong class="text-info" t-esc="project.assigned_tasks"/>
                                    </span>
                                    <span class="text-muted me-2">
                                        <t t-esc="_t('Pending:')"/> <strong class="text-warning" t-esc="project.pending_tasks"/>
                                    </span>
                                    <span class="text-muted me-2">
                                        <t t-esc="_t('Approved:')"/> <strong class="text-success" t-esc="project.approved_tasks"/>
                                    </span>
                                    <span class="text-muted">
                                        <t t-esc="_t('Rejected:')"/> <strong class="text-danger" t-esc="project.rejected_tasks"/>
                                    </span>
                                </div>
                            </div>

                            <!-- Phase Breakdown -->
                            <t t-if="project.phases and project.phases.length">
                                <h6 class="section-title mt-3"><t t-esc="_t('Phases')"/></h6>
                                <table class="table table-sm table-bordered mb-3">
                                    <thead>
                                        <tr>
                                            <th><t t-esc="_t('Phase')"/></th>
                                            <th><t t-esc="_t('Weight')"/></th>
                                            <th><t t-esc="_t('Completion')"/></th>
                                            <th><t t-esc="_t('Contribution')"/></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="project.phases" t-as="phase" t-key="phase.id">
                                            <tr>
                                                <td t-esc="phase.name"/>
                                                <td><t t-esc="phase.percentage"/>%</td>
                                                <td>
                                                    <div class="progress" style="height: 18px;">
                                                        <div class="progress-bar bg-success"
                                                             t-attf-style="width: #{phase.completion_rate}%">
                                                            <t t-esc="phase.completion_rate"/>%
                                                        </div>
                                                    </div>
                                                </td>
                                                <td><t t-esc="phase.effective_progress"/>%</td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </t>

                            <!-- Member Activity Table -->
                            <h6 class="section-title mt-3"><t t-esc="_t('Team Members')"/></h6>
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th><t t-esc="_t('Member')"/></th>
                                        <th><t t-esc="_t('Tasks')"/></th>
                                        <th><t t-esc="_t('Hours')"/></th>
                                        <th><t t-esc="_t('Approval Rate')"/></th>
                                        <th><t t-esc="_t('Late Entries')"/></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="project.members" t-as="member" t-key="member.id">
                                        <tr>
                                            <td t-esc="member.name"/>
                                            <td t-esc="member.task_count"/>
                                            <td t-esc="member.hours"/>
                                            <td>
                                                <span t-attf-class="#{member.approval_rate >= 80 ? 'text-success' : 'text-warning'}"
                                                      t-esc="member.approval_rate + '%'"/>
                                            </td>
                                            <td>
                                                <span t-if="member.late_entries > 0"
                                                      class="text-danger fw-bold"
                                                      t-esc="member.late_entries"/>
                                                <span t-else="">0</span>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </t>
            </div>
        </Layout>
    </t>

    <!-- Admin Dashboard -->
    <t t-name="task_project_management.AdminDashboard">
        <Layout display="display" className="'o_action task_dashboard admin_dashboard'">
            <div class="container-fluid py-3">

                <!-- Header with Logo -->
                <div class="dashboard-header">
                    <div class="header-left">
                        <img class="company-logo" src="/web/binary/company_logo" t-att-alt="_t('Logo')"/>
                        <div>
                            <h2 class="dashboard-title"><t t-esc="_t('Manager Dashboard')"/></h2>
                            <p class="company-name" t-esc="state.companyName"/>
                        </div>
                    </div>
                    <div class="header-actions">
                        <button class="btn btn-outline-light me-2"
                                t-on-click="onExportCSV">
                            <i class="fa fa-file-text-o"/> CSV
                        </button>
                        <button class="btn btn-outline-light me-2"
                                t-on-click="onExportPDF">
                            <i class="fa fa-file-pdf-o"/> PDF
                        </button>
                        <button class="btn btn-outline-light"
                                t-on-click="onExportImage">
                            <i class="fa fa-image"/> <t t-esc="_t('Image')"/>
                        </button>
                    </div>
                </div>

                <!-- Organization KPIs -->
                <div class="row mb-4">
                    <div class="col-md-3">
                        <div class="card kpi-card border-primary">
                            <div class="card-body text-center">
                                <h6 class="text-muted"><t t-esc="_t('Total Projects')"/></h6>
                                <h2 class="text-primary" t-esc="state.totalProjects"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card kpi-card border-success">
                            <div class="card-body text-center">
                                <h6 class="text-muted"><t t-esc="_t('Total Members')"/></h6>
                                <h2 class="text-success" t-esc="state.totalMembers"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card kpi-card border-info">
                            <div class="card-body text-center">
                                <h6 class="text-muted"><t t-esc="_t('Total Hours')"/></h6>
                                <h2 class="text-info" t-esc="state.totalHours"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card kpi-card border-danger">
                            <div class="card-body text-center">
                                <h6 class="text-muted"><t t-esc="_t('Late Entries')"/></h6>
                                <h2 class="text-danger" t-esc="state.totalLateEntries"/>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- All Projects Summary -->
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header">
                                <h5><t t-esc="_t('All Projects')"/></h5>
                            </div>
                            <div class="card-body p-0">
                                <table class="table table-striped mb-0">
                                    <thead>
                                        <tr>
                                            <th><t t-esc="_t('Project')"/></th>
                                            <th><t t-esc="_t('Status')"/></th>
                                            <th><t t-esc="_t('Progress')"/></th>
                                            <th><t t-esc="_t('Tasks')"/></th>
                                            <th><t t-esc="_t('Pending')"/></th>
                                            <th><t t-esc="_t('Approved')"/></th>
                                            <th><t t-esc="_t('Rejected')"/></th>
                                            <th><t t-esc="_t('Members')"/></th>
                                            <th><t t-esc="_t('Late Entries')"/></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-if="!state.projects.length">
                                            <tr>
                                                <td colspan="9" class="text-center text-muted py-4">
                                                    <t t-esc="_t('No projects found. Create a project to see data here.')"/>
                                                </td>
                                            </tr>
                                        </t>
                                        <t t-foreach="state.projects" t-as="project" t-key="project.id">
                                            <tr>
                                                <td t-esc="project.name"/>
                                                <td>
                                                    <span t-attf-class="badge #{project.status === 'active' ? 'text-bg-success' : project.status === 'on_hold' ? 'text-bg-warning' : project.status === 'completed' ? 'text-bg-info' : project.status === 'waiting' ? 'text-bg-danger' : 'text-bg-secondary'}"
                                                          t-esc="project.status_display || project.status"/>
                                                </td>
                                                <td>
                                                    <div class="progress" style="height: 20px; min-width: 100px;">
                                                        <div class="progress-bar"
                                                             t-attf-style="width: #{project.progress}%">
                                                            <t t-esc="project.progress"/>%
                                                        </div>
                                                    </div>
                                                </td>
                                                <td t-esc="project.task_count"/>
                                                <td t-esc="project.pending_tasks"/>
                                                <td t-esc="project.approved_tasks"/>
                                                <td t-esc="project.rejected_tasks"/>
                                                <td t-esc="project.member_count"/>
                                                <td>
                                                    <span t-if="project.late_entries > 0"
                                                          class="text-danger fw-bold"
                                                          t-esc="project.late_entries"/>
                                                    <span t-else="">0</span>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </Layout>
    </t>

</templates>
