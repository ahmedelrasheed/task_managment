<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_res_config_settings_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.task.management</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Task Management"
                     string="Task Management"
                     name="task_project_management"
                     groups="task_project_management.group_admin_manager">
                    <div id="task_entry_settings">
                        <block title="Task Entry Settings" name="task_entry_settings_block">
                            <setting id="past_date_limit_setting"
                                     string="Past Date Limit"
                                     help="Number of days in the past a member can enter tasks">
                                <div class="content-group">
                                    <div class="row mt16">
                                        <label for="task_past_date_limit"
                                               class="col-lg-3 o_light_label"/>
                                        <field name="task_past_date_limit"/>
                                        <span class="ms-1">days</span>
                                    </div>
                                </div>
                            </setting>
                            <setting id="after_midnight_setting"
                                     string="After-Midnight Tasks"
                                     help="Allow members to log tasks that span past midnight">
                                <div class="content-group">
                                    <div class="mt16">
                                        <field name="task_allow_after_midnight"/>
                                        <label for="task_allow_after_midnight"/>
                                    </div>
                                </div>
                            </setting>
                            <setting id="max_attachment_size_setting"
                                     string="Max Attachment Size"
                                     help="Maximum file size for task attachments">
                                <div class="content-group">
                                    <div class="row mt16">
                                        <label for="task_max_attachment_size"
                                               class="col-lg-3 o_light_label"/>
                                        <field name="task_max_attachment_size"/>
                                        <span class="ms-1">MB</span>
                                    </div>
                                </div>
                            </setting>
                        </block>
                    </div>
                    <div id="performance_target_settings">
                        <block title="Member Performance Targets"
                               name="performance_target_block">
                            <setting id="daily_hours_setting"
                                     string="Daily Hours Target"
                                     help="Target average daily working hours for member performance">
                                <div class="content-group">
                                    <div class="row mt16">
                                        <label for="task_daily_hours_average"
                                               class="col-lg-3 o_light_label"/>
                                        <field name="task_daily_hours_average"/>
                                        <span class="ms-1">hours</span>
                                    </div>
                                </div>
                            </setting>
                            <setting id="weekly_hours_setting"
                                     string="Weekly Hours Target"
                                     help="Target average weekly working hours for member performance">
                                <div class="content-group">
                                    <div class="row mt16">
                                        <label for="task_weekly_hours_average"
                                               class="col-lg-3 o_light_label"/>
                                        <field name="task_weekly_hours_average"/>
                                        <span class="ms-1">hours</span>
                                    </div>
                                </div>
                            </setting>
                            <setting id="monthly_off_days_setting"
                                     string="Monthly Off Days"
                                     help="Number of off days (holidays) per month to subtract from working days when calculating monthly target.">
                                <div class="content-group">
                                    <div class="row mt16">
                                        <label for="task_monthly_off_days"
                                               class="col-lg-3 o_light_label"/>
                                        <field name="task_monthly_off_days"/>
                                        <span class="ms-1">days</span>
                                    </div>
                                </div>
                            </setting>
                        </block>
                    </div>
                </app>
            </xpath>
        </field>
    </record>

    <!-- Settings Action -->
    <record id="action_task_management_config" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'task_project_management'}</field>
    </record>

</odoo>
