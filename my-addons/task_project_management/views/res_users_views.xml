<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add Font Size to User Preferences -->
    <record id="view_users_form_inherit_font_size" model="ir.ui.view">
        <field name="name">res.users.form.inherit.task.font.size</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form_simple_modif"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="before">
                <div class="alert alert-info text-center" role="status"
                     style="margin: 0 0 10px 0; border-radius: 8px; padding: 8px 16px;">
                    <div class="d-flex align-items-center justify-content-center gap-3">
                        <span class="fw-bold">
                            <i class="fa fa-text-height me-1"/>
                            Font Size:
                        </span>
                        <field name="task_font_size" widget="radio"
                               options="{'horizontal': true}"/>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

    <!-- Override Change Password wizard: single page with all fields -->
    <record id="change_password_own_form_inherit" model="ir.ui.view">
        <field name="name">change.password.own.form.inherit</field>
        <field name="model">change.password.own</field>
        <field name="inherit_id" ref="base.change_password_own_form"/>
        <field name="arch" type="xml">
            <field name="new_password" position="before">
                <field name="current_password" password="True" required="1"
                       placeholder="Enter current password"/>
            </field>
        </field>
    </record>

</odoo>
