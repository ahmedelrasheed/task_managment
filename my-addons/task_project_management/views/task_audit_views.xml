<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Audit Trail Tree View -->
    <record id="view_task_audit_tree" model="ir.ui.view">
        <field name="name">task.management.task.audit.tree</field>
        <field name="model">task.management.task.audit</field>
        <field name="arch" type="xml">
            <tree string="Audit Trail" create="0" edit="0" delete="0">
                <field name="task_id"/>
                <field name="changed_at"/>
                <field name="old_status" widget="badge"/>
                <field name="new_status" widget="badge"
                       decoration-warning="new_status == 'pending'"
                       decoration-success="new_status == 'approved'"
                       decoration-danger="new_status == 'rejected'"
                       decoration-info="new_status == 'assigned'"/>
                <field name="changed_by"/>
                <field name="previous_comment"/>
                <field name="comment"/>
            </tree>
        </field>
    </record>

    <!-- Audit Trail Form View -->
    <record id="view_task_audit_form" model="ir.ui.view">
        <field name="name">task.management.task.audit.form</field>
        <field name="model">task.management.task.audit</field>
        <field name="arch" type="xml">
            <form string="Audit Entry" create="0" edit="0" delete="0">
                <sheet>
                    <group string="Status Change">
                        <group>
                            <field name="task_id"/>
                            <field name="changed_by"/>
                            <field name="changed_at"/>
                        </group>
                        <group>
                            <field name="old_status" widget="badge"/>
                            <field name="new_status" widget="badge"
                                   decoration-warning="new_status == 'pending'"
                                   decoration-success="new_status == 'approved'"
                                   decoration-danger="new_status == 'rejected'"
                                   decoration-info="new_status == 'assigned'"/>
                        </group>
                    </group>
                    <group string="Comments">
                        <field name="previous_comment"/>
                        <field name="comment"/>
                    </group>
                    <separator string="Task Snapshot"/>
                    <group>
                        <group>
                            <field name="snap_date"/>
                            <field name="snap_project_name"/>
                            <field name="snap_phase_name"/>
                            <field name="snap_task_type"/>
                            <field name="snap_approval_status" widget="badge"/>
                        </group>
                        <group>
                            <field name="snap_time_from" widget="float_time"/>
                            <field name="snap_time_to" widget="float_time"/>
                            <field name="snap_duration_hours" widget="float_time"/>
                        </group>
                    </group>
                    <group>
                        <field name="snap_description"/>
                    </group>
                    <group>
                        <field name="snap_manager_comment"/>
                    </group>
                    <group invisible="snap_task_type != 'assigned'"
                           string="Assignment Details">
                        <group>
                            <field name="snap_assignment_name"/>
                            <field name="snap_due_date"/>
                        </group>
                        <group>
                            <field name="snap_assignment_description"/>
                        </group>
                    </group>
                    <separator string="Attachments"/>
                    <field name="snap_attachment_ids" widget="many2many_binary"/>
                    <field name="snap_assignment_attachment_ids" widget="many2many_binary"
                           invisible="snap_task_type != 'assigned'"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Audit Trail Search View -->
    <record id="view_task_audit_search" model="ir.ui.view">
        <field name="name">task.management.task.audit.search</field>
        <field name="model">task.management.task.audit</field>
        <field name="arch" type="xml">
            <search string="Search Audit Trail">
                <field name="task_id"/>
                <field name="changed_by"/>
                <separator/>
                <filter string="Approved" name="filter_approved"
                        domain="[('new_status', '=', 'approved')]"/>
                <filter string="Rejected" name="filter_rejected"
                        domain="[('new_status', '=', 'rejected')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Task" name="group_task"
                            context="{'group_by': 'task_id'}"/>
                    <filter string="Changed By" name="group_changed_by"
                            context="{'group_by': 'changed_by'}"/>
                    <filter string="New Status" name="group_status"
                            context="{'group_by': 'new_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Audit Trail Action -->
    <record id="action_task_audit" model="ir.actions.act_window">
        <field name="name">Audit Trail</field>
        <field name="res_model">task.management.task.audit</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
