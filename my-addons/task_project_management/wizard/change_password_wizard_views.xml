<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_change_password_wizard_form" model="ir.ui.view">
        <field name="name">task.management.change.password.wizard.form</field>
        <field name="model">task.management.change.password.wizard</field>
        <field name="arch" type="xml">
            <form string="Change Password">
                <group>
                    <field name="member_id"/>
                    <field name="new_password" password="True"/>
                </group>
                <footer>
                    <button name="action_confirm" string="Change Password"
                            type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
