<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_export_report_wizard_form" model="ir.ui.view">
        <field name="name">task.management.export.report.wizard.form</field>
        <field name="model">task.management.export.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Export Report">
                <group>
                    <group>
                        <field name="project_id"
                               options="{'no_create': True}"/>
                        <field name="member_id"
                               domain="[('role', '!=', 'manager')]"/>
                    </group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="export_type" widget="radio"/>
                    </group>
                </group>
                <footer>
                    <button name="action_export" string="Export"
                            type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_export_report_wizard" model="ir.actions.act_window">
        <field name="name">Export Report</field>
        <field name="res_model">task.management.export.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
