<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Member Performance Report Form View -->
    <record id="view_member_performance_report_form" model="ir.ui.view">
        <field name="name">member.performance.report.form</field>
        <field name="model">task.management.member.performance.report</field>
        <field name="arch" type="xml">
            <form string="Member Performance Report" create="false" class="o_report_wizard">
                <header>
                    <button name="action_export_csv" string="Export CSV"
                            type="object" class="btn-primary"
                            icon="fa-file-text-o"
                            invisible="not member_id"/>
                    <button name="action_export_png" string="Export PNG"
                            type="object" class="btn-secondary"
                            icon="fa-file-image-o"
                            invisible="not member_id"/>
                    <button name="action_export_pdf" string="Export PDF"
                            type="object" class="btn-secondary"
                            icon="fa-file-pdf-o"
                            invisible="not member_id"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="member_id"
                                   domain="[('role', '!=', 'manager')]"
                                   options="{'no_create': True}"/>
                            <field name="period"/>
                        </group>
                        <group>
                            <field name="date_from"
                                   invisible="period != 'custom'"
                                   required="period == 'custom'"/>
                            <field name="date_to"
                                   invisible="period != 'custom'"
                                   required="period == 'custom'"/>
                        </group>
                    </group>

                    <separator string="Performance Summary"/>

                    <!-- Row 1 — Task Summary (4 × col-md-3) -->
                    <div class="row mb-3">
                        <div class="col-md-3 text-center">
                            <div class="border rounded p-2 bg-light">
                                <small class="text-muted">Total Tasks</small>
                                <h4><field name="total_tasks" class="d-inline"/></h4>
                            </div>
                        </div>
                        <div class="col-md-3 text-center">
                            <div class="border rounded p-2 bg-light">
                                <small class="text-muted">Approved</small>
                                <h4 class="text-success">
                                    <field name="approved_tasks" class="d-inline"/>
                                </h4>
                            </div>
                        </div>
                        <div class="col-md-3 text-center">
                            <div class="border rounded p-2 bg-light">
                                <small class="text-muted">Revision Requests</small>
                                <h4 class="text-danger">
                                    <field name="rejected_tasks" class="d-inline"/>
                                </h4>
                            </div>
                        </div>
                        <div class="col-md-3 text-center">
                            <div class="border rounded p-2 bg-light">
                                <small class="text-muted">Pending</small>
                                <h4 class="text-warning">
                                    <field name="pending_tasks" class="d-inline"/>
                                </h4>
                            </div>
                        </div>
                    </div>

                    <!-- Row 2 — Hours & Rates (4 × col-md-3) -->
                    <div class="row mb-3">
                        <div class="col-md-3 text-center">
                            <div class="border rounded p-2 bg-light">
                                <small class="text-muted">Total Hours</small>
                                <h4><field name="total_hours" widget="float_time"
                                           class="d-inline"/></h4>
                            </div>
                        </div>
                        <div class="col-md-3 text-center">
                            <div class="border rounded p-2 bg-light">
                                <small class="text-muted">Approved Hours</small>
                                <h4 class="text-success">
                                    <field name="approved_hours" widget="float_time"
                                           class="d-inline"/>
                                </h4>
                            </div>
                        </div>
                        <div class="col-md-3 text-center">
                            <div class="border rounded p-2 bg-light">
                                <small class="text-muted">Approval Rate</small>
                                <h4><field name="approval_rate" class="d-inline"/>%</h4>
                            </div>
                        </div>
                        <div class="col-md-3 text-center">
                            <div class="border rounded p-2 bg-light">
                                <small class="text-muted">Avg Hours/Day</small>
                                <h4><field name="avg_hours_per_day" class="d-inline"/></h4>
                            </div>
                        </div>
                    </div>

                    <!-- Row 3 — Performance vs Targets (6 × col-md-2) -->
                    <div class="row mb-3">
                        <div class="col-md-2 text-center">
                            <div class="border rounded p-2 bg-light">
                                <small class="text-muted">Daily Target</small>
                                <h4><field name="daily_target" class="d-inline"/></h4>
                            </div>
                        </div>
                        <div class="col-md-2 text-center">
                            <div class="border rounded p-2 bg-light">
                                <small class="text-muted">Daily Perf.</small>
                                <h4 class="text-success"
                                    invisible="daily_performance &lt; 75">
                                    <field name="daily_performance" class="d-inline"/>%
                                </h4>
                                <h4 class="text-primary"
                                    invisible="daily_performance &lt; 50 or daily_performance &gt;= 75">
                                    <field name="daily_performance" class="d-inline"/>%
                                </h4>
                                <h4 class="text-warning"
                                    invisible="daily_performance &lt; 25 or daily_performance &gt;= 50">
                                    <field name="daily_performance" class="d-inline"/>%
                                </h4>
                                <h4 class="text-danger"
                                    invisible="daily_performance &gt;= 25">
                                    <field name="daily_performance" class="d-inline"/>%
                                </h4>
                            </div>
                        </div>
                        <div class="col-md-2 text-center">
                            <div class="border rounded p-2 bg-light">
                                <small class="text-muted">Weekly Target</small>
                                <h4><field name="weekly_target" class="d-inline"/></h4>
                            </div>
                        </div>
                        <div class="col-md-2 text-center">
                            <div class="border rounded p-2 bg-light">
                                <small class="text-muted">Weekly Perf.</small>
                                <h4 class="text-success"
                                    invisible="weekly_performance &lt; 75">
                                    <field name="weekly_performance" class="d-inline"/>%
                                </h4>
                                <h4 class="text-primary"
                                    invisible="weekly_performance &lt; 50 or weekly_performance &gt;= 75">
                                    <field name="weekly_performance" class="d-inline"/>%
                                </h4>
                                <h4 class="text-warning"
                                    invisible="weekly_performance &lt; 25 or weekly_performance &gt;= 50">
                                    <field name="weekly_performance" class="d-inline"/>%
                                </h4>
                                <h4 class="text-danger"
                                    invisible="weekly_performance &gt;= 25">
                                    <field name="weekly_performance" class="d-inline"/>%
                                </h4>
                            </div>
                        </div>
                        <div class="col-md-2 text-center">
                            <div class="border rounded p-2 bg-light">
                                <small class="text-muted">Monthly Target</small>
                                <h4><field name="monthly_target" class="d-inline"/></h4>
                            </div>
                        </div>
                        <div class="col-md-2 text-center">
                            <div class="border rounded p-2 bg-light">
                                <small class="text-muted">Monthly Perf.</small>
                                <h4 class="text-success"
                                    invisible="monthly_performance &lt; 75">
                                    <field name="monthly_performance" class="d-inline"/>%
                                </h4>
                                <h4 class="text-primary"
                                    invisible="monthly_performance &lt; 50 or monthly_performance &gt;= 75">
                                    <field name="monthly_performance" class="d-inline"/>%
                                </h4>
                                <h4 class="text-warning"
                                    invisible="monthly_performance &lt; 25 or monthly_performance &gt;= 50">
                                    <field name="monthly_performance" class="d-inline"/>%
                                </h4>
                                <h4 class="text-danger"
                                    invisible="monthly_performance &gt;= 25">
                                    <field name="monthly_performance" class="d-inline"/>%
                                </h4>
                            </div>
                        </div>
                    </div>

                    <notebook>
                        <page string="Project Breakdown" name="projects">
                            <field name="project_line_ids" readonly="1">
                                <tree>
                                    <field name="project_name"/>
                                    <field name="task_count" sum="Total"/>
                                    <field name="total_hours" widget="float_time"
                                           sum="Total"/>
                                    <field name="approved_hours" widget="float_time"
                                           sum="Total"/>
                                    <field name="approval_rate"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Task Details" name="tasks">
                            <field name="task_line_ids" readonly="1">
                                <tree decoration-warning="approval_status == 'pending'"
                                      decoration-success="approval_status == 'approved'"
                                      decoration-danger="approval_status == 'rejected'"
                                      decoration-info="approval_status == 'assigned'">
                                    <field name="date"/>
                                    <field name="project_name"/>
                                    <field name="description"/>
                                    <field name="time_from" widget="float_time"/>
                                    <field name="time_to" widget="float_time"/>
                                    <field name="duration_hours" widget="float_time"
                                           sum="Total Hours"/>
                                    <field name="task_type" widget="badge"
                                           decoration-info="task_type == 'assigned'"
                                           decoration-muted="task_type == 'initiated'"/>
                                    <field name="approval_status" widget="badge"
                                           decoration-warning="approval_status == 'pending'"
                                           decoration-success="approval_status == 'approved'"
                                           decoration-danger="approval_status == 'rejected'"
                                           decoration-info="approval_status == 'assigned'"/>
                                    <field name="is_late_entry"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action to open the report -->
    <record id="action_member_performance_report" model="ir.actions.act_window">
        <field name="name">Member Performance Report</field>
        <field name="res_model">task.management.member.performance.report</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

    <!-- Menu item under Members section (PM + Admin) -->
    <menuitem id="menu_member_performance"
              name="Member Performance"
              parent="menu_members_parent"
              action="action_member_performance_report"
              sequence="20"
              active="0"/>

</odoo>
