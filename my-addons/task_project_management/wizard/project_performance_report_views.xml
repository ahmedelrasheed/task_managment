<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Project Performance Report Form View -->
    <record id="view_project_performance_report_form" model="ir.ui.view">
        <field name="name">project.performance.report.form</field>
        <field name="model">task.management.project.performance.report</field>
        <field name="arch" type="xml">
            <form string="Project Performance Report" create="false" class="o_report_wizard">
                <header>
                    <button name="action_export_csv" string="Export CSV"
                            type="object" class="btn-primary"
                            icon="fa-file-text-o"
                            invisible="not project_id"/>
                    <button name="action_export_png" string="Export PNG"
                            type="object" class="btn-secondary"
                            icon="fa-file-image-o"
                            invisible="not project_id"/>
                    <button name="action_export_pdf" string="Export PDF"
                            type="object" class="btn-secondary"
                            icon="fa-file-pdf-o"
                            invisible="not project_id"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="project_id"
                                   options="{'no_create': True}"/>
                            <field name="period"/>
                        </group>
                        <group>
                            <field name="date_from"
                                   invisible="period != 'custom'"
                                   required="period == 'custom'"/>
                            <field name="date_to"
                                   invisible="period != 'custom'"
                                   required="period == 'custom'"/>
                        </group>
                    </group>

                    <separator string="Project Summary"/>

                    <!-- Project info row -->
                    <div class="row mb-3">
                        <div class="col-md-3 text-center">
                            <div class="border rounded p-2 bg-light">
                                <small class="text-muted">Status</small>
                                <h5><field name="project_status" class="d-inline"/></h5>
                            </div>
                        </div>
                        <div class="col-md-3 text-center">
                            <div class="border rounded p-2 bg-light">
                                <small class="text-muted">Phases</small>
                                <h4><field name="phase_count" class="d-inline"/></h4>
                            </div>
                        </div>
                        <div class="col-md-3 text-center">
                            <div class="border rounded p-2 bg-light">
                                <small class="text-muted">Progress</small>
                                <h4><field name="progress" class="d-inline"/>%</h4>
                            </div>
                        </div>
                        <div class="col-md-3 text-center">
                            <div class="border rounded p-2 bg-light">
                                <small class="text-muted">Members</small>
                                <h4><field name="member_count" class="d-inline"/></h4>
                            </div>
                        </div>
                    </div>

                    <!-- KPI Cards -->
                    <div class="row mb-3">
                        <div class="col-md-2 text-center">
                            <div class="border rounded p-2 bg-light">
                                <small class="text-muted">Total Tasks</small>
                                <h4><field name="total_tasks" class="d-inline"/></h4>
                            </div>
                        </div>
                        <div class="col text-center">
                            <div class="border rounded p-2 bg-light">
                                <small class="text-muted">Approved</small>
                                <h4 class="text-success">
                                    <field name="approved_tasks" class="d-inline"/>
                                </h4>
                            </div>
                        </div>
                        <div class="col text-center">
                            <div class="border rounded p-2 bg-light">
                                <small class="text-muted">Rejected</small>
                                <h4 class="text-danger">
                                    <field name="rejected_tasks" class="d-inline"/>
                                </h4>
                            </div>
                        </div>
                        <div class="col text-center">
                            <div class="border rounded p-2 bg-light">
                                <small class="text-muted">Pending</small>
                                <h4 class="text-warning">
                                    <field name="pending_tasks" class="d-inline"/>
                                </h4>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-4 text-center">
                            <div class="border rounded p-2 bg-light">
                                <small class="text-muted">Late Entries</small>
                                <h4 class="text-danger">
                                    <field name="late_entries" class="d-inline"/>
                                </h4>
                            </div>
                        </div>
                        <div class="col-md-4 text-center">
                            <div class="border rounded p-2 bg-light">
                                <small class="text-muted">Approval Rate</small>
                                <h4><field name="approval_rate" class="d-inline"/>%</h4>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6 text-center">
                            <div class="border rounded p-2 bg-light">
                                <small class="text-muted">Total Hours Logged</small>
                                <h4><field name="total_hours" widget="float_time"
                                           class="d-inline"/></h4>
                            </div>
                        </div>
                        <div class="col-md-6 text-center">
                            <div class="border rounded p-2 bg-light">
                                <small class="text-muted">Approved Hours</small>
                                <h4 class="text-success">
                                    <field name="approved_hours" widget="float_time"
                                           class="d-inline"/>
                                </h4>
                            </div>
                        </div>
                    </div>

                    <notebook>
                        <page string="Member Breakdown" name="members">
                            <field name="member_line_ids" readonly="1">
                                <tree>
                                    <field name="member_name"/>
                                    <field name="role" widget="badge"
                                           decoration-info="role == 'member'"
                                           decoration-warning="role == 'project_manager'"
                                           decoration-danger="role == 'admin_manager'"/>
                                    <field name="task_count" sum="Total"/>
                                    <field name="total_hours" widget="float_time"
                                           sum="Total"/>
                                    <field name="approved_hours" widget="float_time"
                                           sum="Total"/>
                                    <field name="approval_rate"/>
                                    <field name="pending_count" sum="Total"/>
                                    <field name="rejected_count" sum="Total"/>
                                    <field name="late_entries" sum="Total"/>
                                    <field name="avg_hours_per_day"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Phase Breakdown" name="phases">
                            <field name="phase_line_ids" readonly="1">
                                <tree>
                                    <field name="phase_name"/>
                                    <field name="percentage"/>
                                    <field name="completion_rate" widget="progressbar"/>
                                    <field name="effective_progress"/>
                                </tree>
                            </field>
                        </page>
                        <page string="All Tasks" name="tasks">
                            <field name="task_line_ids" readonly="1">
                                <tree decoration-warning="approval_status == 'pending'"
                                      decoration-success="approval_status == 'approved'"
                                      decoration-danger="approval_status == 'rejected'"
                                      decoration-info="approval_status == 'assigned'">
                                    <field name="date"/>
                                    <field name="member_name"/>
                                    <field name="description"/>
                                    <field name="time_from" widget="float_time"/>
                                    <field name="time_to" widget="float_time"/>
                                    <field name="duration_hours" widget="float_time"
                                           sum="Total Hours"/>
                                    <field name="task_type" widget="badge"
                                           decoration-info="task_type == 'assigned'"
                                           decoration-muted="task_type == 'initiated'"/>
                                    <field name="approval_status" widget="badge"
                                           decoration-warning="approval_status == 'pending'"
                                           decoration-success="approval_status == 'approved'"
                                           decoration-danger="approval_status == 'rejected'"
                                           decoration-info="approval_status == 'assigned'"/>
                                    <field name="is_late_entry"/>
                                    <field name="manager_comment"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_project_performance_report" model="ir.actions.act_window">
        <field name="name">Project Performance Report</field>
        <field name="res_model">task.management.project.performance.report</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

    <!-- Menu item under Projects section -->
    <menuitem id="menu_project_performance"
              name="Project Report"
              parent="menu_projects_parent"
              action="action_project_performance_report"
              sequence="22"
              active="0"/>

</odoo>
